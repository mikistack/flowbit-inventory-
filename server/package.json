{
  "name": "inventory-backend",
  "version": "0.1.0",
  "description": "Cloud-hosted inventory & stock management API for multi-branch retailers.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "node scripts/syntax-check.js",
    "migrate": "sequelize --config sequelize-cli-config.js db:migrate",
    "seed": "sequelize --config sequelize-cli-config.js db:seed:all",
    "test": "node --test"
  },
  "keywords": [
    "inventory",
    "express",
    "postgres",
    "multi-branch"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.63.0",
    "bwip-js": "^4.7.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-validator": "^7.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "otplib": "^12.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "sequelize-cli": "^6.6.3"
  }
}
