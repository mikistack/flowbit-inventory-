# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_TZ=Africa/Addis_Ababa
# Comma-separated origins. Wildcards like https://*.trycloudflare.com are supported.
CORS_ORIGIN=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASSWORD=change-me
DB_LOGGING=false

# ─── Seed ────────────────────────────────────────────────────────────────────
# Set to true to populate warehouses, a sample product, and roles on first start.
SEED_SAMPLE_DATA=false

# ─── Auth ────────────────────────────────────────────────────────────────────
# REQUIRED: Replace both secrets with strong random values before deployment.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_DEFAULT_PASSWORD=Admin@123
ADMIN_FORCE_PASSWORD_RESET=true

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
UPLOAD_DIR=./storage/uploads
REPORT_DIR=./storage/reports

# ─── Email (optional) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=starttls

# ─── Twilio (optional) ───────────────────────────────────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Telegram (optional) ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
