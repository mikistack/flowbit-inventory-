# API base path used by Axios in the browser.
# Keep as /api when the frontend and backend share the same origin (e.g. Docker or reverse proxy).
VITE_API_BASE_URL=/api

# Vite dev proxy target. Only used during `npm run dev`.
# The dev server proxies /api requests to this address so you don't need CORS in dev.
VITE_PROXY_API_TARGET=http://127.0.0.1:4000
