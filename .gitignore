.env
server/.env
web/.env
*.env.local
*.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
web/dist/
server/dist/
build/

# Runtime storage (uploads, reports, backups)
server/storage/uploads/
server/storage/reports/
server/storage/backups/
server/storage/

# Database volume (Docker)
pg-data/

# Debug screenshots (generated by builder.sh)
docs/screenshots/debug-*.png
docs/screenshots/trace-*.png

# OS artifacts
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/

# Vite cache
.vite/

# Misc
*.tgz
*.tar.gz
